# Copy to `.env` and adjust for local development.

NODE_ENV=development
PORT=3000

# Database (see README for full setup)
# DATABASE_URL=postgresql://...

# Frontend base URL — used for recipient feedback links in SMS
# Must match where the Vite app runs (default Vite port 5173 or your proxy).
FRONTEND_APP_BASE_URL=http://localhost:5173

# --- Recipient transaction SMS (two channels) ---
#
# 1) Broker B accept → delivery auth code + expected amount
#    Prefer Twilio Messages when TWILIO_FROM_NUMBER is set (full custom body).
#    Falls back to Twilio Verify (code only via template) if Messages is not configured.
#
# 2) After Broker B confirms delivery → feedback link (/feedback/:token)
#    Requires Twilio Messages (TWILIO_FROM_NUMBER). Verify alone is not enough.

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_VERIFY_SERVICE_SID=

# Email (SendGrid)
SENDGRID_API_KEY=
EMAIL_FROM=
