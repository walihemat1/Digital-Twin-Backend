NODE_ENV=development
PORT=3000
API_PREFIX=api
SERVICE_NAME=digital-twin-backend

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=digital_twin
DB_SCHEMA=public
DB_SSL=false
DB_SYNCHRONIZE=false
DB_LOGGING=false

JWT_ACCESS_TOKEN_SECRET=change-this-access-secret-min-16-chars
JWT_ACCESS_TOKEN_EXPIRES_IN=15m
JWT_REFRESH_TOKEN_SECRET=change-this-refresh-secret-min-16-chars
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

# Optional (Milestone 2+)
# SENDGRID_API_KEY=
# EMAIL_FROM=
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=
