NODE_ENV=development
PORT=3000
API_PREFIX=api
SERVICE_NAME=digital-twin-backend

DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=digital_twin
