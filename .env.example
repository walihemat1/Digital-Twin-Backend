JWT_REFRESH_TOKEN_SECRET=change-this-refresh-secret
JWT_REFRESH_TOKEN_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=12

MFA_CODE_TTL_SECONDS=300
PASSWORD_RESET_TOKEN_TTL_MINUTES=30

SENDGRID_API_KEY=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
